# ═══════════════════════════════════════════════════════════
# Multi-Agent System — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════

# ── LLM Provider ────────────────────────────────────────────────────────────
# At least one of the following provider blocks must be configured.
# The system has no built-in model default — set what you use.

# Option A: Azure OpenAI (recommended for production)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com
AZURE_ORCHESTRATOR_DEPLOYMENT=          # primary model (analysis + chat)
AZURE_DATA_DEPLOYMENT=                  # fast model for tool-calling steps (optional, falls back to primary)
AZURE_ANALYSIS_DEPLOYMENT=              # high-quality model for final insight text (optional)
AZURE_FALLBACK_DEPLOYMENT=              # fallback if primary is unavailable (optional)
AZURE_ORCHESTRATOR_TEMPERATURE=0.1
AZURE_DATA_TEMPERATURE=0

# Option B: Ollama Cloud / OpenAI-compatible endpoint
# ORCHESTRATOR_MODEL=                   # model name as understood by the endpoint
# OLLAMA_CLOUD_URL=https://ollama.com/v1
# OLLAMA_CLOUD_API_KEY=

# Option C: Direct provider keys (LiteLLM model string, e.g. gpt-4o, claude-sonnet-4-6)
# LLM_MODEL=
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Model for embeddings (insight vector store)
EMBEDDING_MODEL=text-embedding-3-small

# ── MCP Connectors (already connected in Claude.ai) ─────────────────────────
# Pipeboard — Meta + Google Ads
PIPEBOARD_TOKEN=
PIPEBOARD_MCP_URL=https://meta-ads.mcp.pipeboard.co

# Seleric — Cube semantic layer
SELERIC_MCP_URL=https://mcp.seleric.com/sse   # MCP SSE endpoint (used by Claude.ai)
SELERIC_API_KEY=
# Cube MCP server — orchestrator calls this for metrics (same server Claude.ai uses)
# CUBE_MCP_URL takes precedence over SELERIC_MCP_URL if both are set.
# Local self-hosted Cube MCP:  http://localhost:4000/mcp
# Seleric cloud MCP:           https://mcp.seleric.com/sse
CUBE_MCP_URL=https://mcp.seleric.com/sse

# ── ClickHouse (existing data warehouse) ────────────────────────────────────
CLICKHOUSE_URL=https://your-instance.clickhouse.cloud
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=analytics
CLICKHOUSE_PORT=8443

# ── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_STORE_DOMAIN=yourstore.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_...
# Webhook HMAC secret — from Shopify Partner dashboard
SHOPIFY_WEBHOOK_SECRET=
# API version — use a stable version
SHOPIFY_API_VERSION=2024-10

# ── Databases (local dev defaults shown) ────────────────────────────────────
DATABASE_URL=postgresql://multiagent:localdev@localhost:5432/multiagent
REDIS_URL=redis://localhost:6379

# ── Service URLs ─────────────────────────────────────────────────────────────
ORCHESTRATOR_API_URL=http://localhost:8000
MCP_SHOPIFY_URL=http://localhost:3100
# Public URL — used for frontend environment
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── Write Controls ────────────────────────────────────────────────────────────
# CRITICAL: Set to "false" until Phase 3 is fully tested.
# When false, all write MCP tools (budget changes, pauses, product updates) are blocked.
WRITE_ENABLED=false

# ── Auth ─────────────────────────────────────────────────────────────────────
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Notifications ─────────────────────────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
SLACK_CHANNEL=#alerts

# Resend (email) — https://resend.com
RESEND_API_KEY=re_...
NOTIFICATION_EMAIL_FROM=alerts@yourdomain.com
NOTIFICATION_EMAIL_TO=founder@yourdomain.com

# ── Approval Queue ────────────────────────────────────────────────────────────
# HMAC secret for signed approval URLs — generate with: openssl rand -hex 32
APPROVAL_SIGNING_SECRET=
# Base URL used to construct approval links in notifications
APP_BASE_URL=http://localhost:3000

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Axiom log aggregation
AXIOM_DATASET=multiagent-logs
AXIOM_API_TOKEN=

# ── Environment ───────────────────────────────────────────────────────────────
# "development" | "staging" | "production"
ENVIRONMENT=development
# Log level: "debug" | "info" | "warning" | "error"
LOG_LEVEL=debug


ORCHESTRATOR_TEMPERATURE=0.3