## Redis key schema — never deviate from this

| Key pattern | Type | TTL | Purpose |
|---|---|---|---|
| `entity:{type}:{id}:session` | Hash | 24h | Orchestrator session state |
| `entity:{type}:{id}:metrics` | String (JSON) | 5min | Cached Cube metrics |
| `signal:{id}:status` | String | 1h | Signal processing status |
| `approval:{id}:token` | String | 48h | Signed approval link token |
| `chat:{session_id}:history` | List | 2h | Chat message history |
| `cache:cube:{hash}` | String (JSON) | 5min | Cube query result cache |
| `ratelimit:{service}:{key}` | String | 1min | Rate limiting counters |

### Redis client (Python)
```python
# services/orchestrator/src/memory/redis_client.py
import aioredis
import os

_client: aioredis.Redis | None = None

async def get_client() -> aioredis.Redis:
    global _client
    if _client is None:
        _client = await aioredis.from_url(os.getenv("REDIS_URL"), decode_responses=True)
    return _client

async def get_session(entity_type: str, entity_id: str) -> dict | None:
    client = await get_client()
    data = await client.get(f"entity:{entity_type}:{entity_id}:session")
    return json.loads(data) if data else None

async def set_session(entity_type: str, entity_id: str, session: dict, ttl_seconds: int = 86400):
    client = await get_client()
    await client.setex(f"entity:{entity_type}:{entity_id}:session", ttl_seconds, json.dumps(session))
```

## ClickHouse query patterns

### Always filter by date — ClickHouse scans are expensive
```sql
-- Good: date partition filter
SELECT campaign_id, sum(spend), sum(conversions)
FROM ad_spend
WHERE date >= today() - 7
GROUP BY campaign_id

-- Bad: no date filter (full table scan)
SELECT * FROM ad_spend WHERE campaign_id = 'abc'
```

### Use parameterized queries via ClickHouse HTTP API
```python
import httpx

async def query_clickhouse(sql: str, params: dict = {}) -> list[dict]:
    validate_query(sql)  # Always validate first
    async with httpx.AsyncClient() as client:
        response = await client.post(
            f"{os.getenv('CLICKHOUSE_URL')}/query",
            json={"query": sql, "params": params, "format": "JSONEachRow"},
            auth=(os.getenv("CLICKHOUSE_USER"), os.getenv("CLICKHOUSE_PASSWORD")),
            timeout=30.0,
        )
        response.raise_for_status()
        return [json.loads(line) for line in response.text.strip().split("\n") if line]
```

### Key ClickHouse tables (document these for agent context)
```sql
-- ad_spend: daily ad performance
CREATE TABLE ad_spend (
  date Date,
  account_id String,
  campaign_id String,
  adset_id String,
  ad_id String,
  platform Enum('meta', 'google'),
  spend Float64,
  impressions UInt64,
  clicks UInt64,
  conversions UInt32,
  revenue Float64
) ENGINE = MergeTree() PARTITION BY toYYYYMM(date) ORDER BY (date, campaign_id);

-- orders: Shopify orders
CREATE TABLE orders (
  order_id String,
  created_at DateTime,
  total_price Float64,
  subtotal_price Float64,
  discount_amount Float64,
  product_ids Array(String),
  customer_id String,
  channel String,  -- 'web', 'mobile', 'pos'
  utm_source String,
  utm_campaign String
) ENGINE = MergeTree() ORDER BY (created_at, customer_id);
```

## BullMQ job definitions (TypeScript, services/worker)
```typescript
// services/worker/src/jobs/execute-action.ts
import { Job } from "bullmq"
import { db } from "@multiagent/db"

export interface ExecuteActionJob {
  pendingActionId: string
  approvedBy: string
}

export async function processExecuteAction(job: Job<ExecuteActionJob>) {
  const action = await db.pendingAction.findUnique({
    where: { id: job.data.pendingActionId },
  })
  if (!action || action.status !== "APPROVED") {
    throw new Error(`Action ${job.data.pendingActionId} not in APPROVED state`)
  }
  // Execute via MCP tool call, update status, log outcome
}
```

